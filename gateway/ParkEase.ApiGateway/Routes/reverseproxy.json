{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "parkinglot-route": {
        "ClusterId": "parkinglot-cluster",
        "Match": {
          "Path": "/api/v1/parkinglots/{**catch-all}"
        }
      },
      "spot-route": {
        "ClusterId": "spot-cluster",
        "Match": {
          "Path": "/api/v1/spots/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": {
          "Path": "/api/v1/vehicles/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "parkinglot-cluster": {
        "Destinations": {
          "parkinglot-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "spot-cluster": {
        "Destinations": {
          "spot-destination": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-destination": {
            "Address": "http://localhost:5005/"
          }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "vehicle-destination": {
            "Address": "http://localhost:5006/"
          }
        }
      }
    }
  }
}
