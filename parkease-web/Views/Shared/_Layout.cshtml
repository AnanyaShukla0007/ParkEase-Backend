<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ParkEase Web</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(180deg, #f4efe6 0%, #ffffff 60%); }
        .hero { background: linear-gradient(135deg, #0f4c5c, #2c7a7b); color: #fff; border-radius: 1.25rem; }
        .card-soft { border: 0; border-radius: 1rem; box-shadow: 0 12px 30px rgba(15, 76, 92, .08); }
        .stat { font-size: 2rem; font-weight: 700; color: #0f4c5c; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">ParkEase</a>
            <div class="navbar-nav ms-auto gap-2">
                <a class="nav-link" asp-controller="Driver" asp-action="Dashboard">Driver</a>
                <a class="nav-link" asp-controller="LotManager" asp-action="Dashboard">Manager</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin</a>
                <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Login">Login</a>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>
</body>
</html>
